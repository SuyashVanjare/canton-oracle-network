module OracleTest where

import Daml.Script
import Oracle.PriceFeed
import Oracle.Aggregator
import Oracle.ProviderRegistry

test_oracle_aggregation : Script ()
test_oracle_aggregation = script do
  authority <- allocateParty "OracleAuthority"
  p1        <- allocateParty "Provider-Bloomberg"
  p2        <- allocateParty "Provider-Reuters"
  p3        <- allocateParty "Provider-ICE"
  consumer  <- allocateParty "DeFiApp"

  now <- getTime

  -- Register three approved providers
  reg1 <- submit authority do
    createCmd ProviderRegistration with
      provider = p1; authority; stake = 10000.0; approvedAt = now
  reg2 <- submit authority do
    createCmd ProviderRegistration with
      provider = p2; authority; stake = 10000.0; approvedAt = now
  reg3 <- submit authority do
    createCmd ProviderRegistration with
      provider = p3; authority; stake = 10000.0; approvedAt = now

  -- Submit three price feeds for EUR/USD
  feed1 <- submit p1 do
    createCmd PriceFeed with
      provider = p1; authority; pair = "EUR/USD"
      price = 1.0823; timestamp = now; source = "Bloomberg"
  feed2 <- submit p2 do
    createCmd PriceFeed with
      provider = p2; authority; pair = "EUR/USD"
      price = 1.0825; timestamp = now; source = "Reuters"
  feed3 <- submit p3 do
    createCmd PriceFeed with
      provider = p3; authority; pair = "EUR/USD"
      price = 1.0824; timestamp = now; source = "ICE"

  -- Aggregate: trimmed median of [1.0823, 1.0824, 1.0825] = 1.0824
  aggCid <- submit authority do
    createCmd AggregatedPrice with
      pair = "EUR/USD"; authority
      prices = [1.0823, 1.0824, 1.0825]
      aggregatedPrice = 1.0824
      providers = [p1, p2, p3]
      computedAt = now

  return ()

test_outlier_rejection : Script ()
test_outlier_rejection = script do
  authority <- allocateParty "OracleAuthority"
  p1 <- allocateParty "Provider-A"
  p2 <- allocateParty "Provider-B"
  p3 <- allocateParty "Provider-C"

  now <- getTime

  -- One provider submits an outlier (10x the market rate)
  feed1 <- submit p1 do
    createCmd PriceFeed with
      provider = p1; authority; pair = "BTC/USD"
      price = 95000.0; timestamp = now; source = "Exchange-A"
  feed2 <- submit p2 do
    createCmd PriceFeed with
      provider = p2; authority; pair = "BTC/USD"
      price = 94800.0; timestamp = now; source = "Exchange-B"
  feed3 <- submit p3 do
    createCmd PriceFeed with
      provider = p3; authority; pair = "BTC/USD"
      price = 950000.0; timestamp = now; source = "Outlier"  -- bogus

  -- Trimmed median drops the outlier; result is ~94900
  aggCid <- submit authority do
    createCmd AggregatedPrice with
      pair = "BTC/USD"; authority
      prices = [94800.0, 95000.0]  -- outlier trimmed
      aggregatedPrice = 94900.0
      providers = [p1, p2]
      computedAt = now

  return ()
